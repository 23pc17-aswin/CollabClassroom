# ─────────────────────────────────────────────────
#  CollabClassroom V2 — Backend Environment Variables
#
#  FOR LOCAL DEV: matches docker-compose.yml defaults.
#  FOR PRODUCTION: Replace values with managed service URLs.
# ─────────────────────────────────────────────────

NODE_ENV=development
PORT=8000

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── PostgreSQL (Local Docker → swap for Neon URL in prod) ──
# Local:      postgresql://ccadmin:ccpassword@localhost:5432/collabclassroom
# Production: postgresql://USER:PASS@ep-xxx.neon.tech/collabclassroom?sslmode=require
DATABASE_URL=postgresql://ccadmin:ccpassword@localhost:5432/collabclassroom

# ── MongoDB (Local Docker → swap for Atlas URI in prod) ──
# Local:      mongodb://ccmongo:ccmongo@localhost:27017/collabclassroom?authSource=admin
# Production: mongodb+srv://USER:PASS@cluster.mongodb.net/collabclassroom
MONGO_URI=mongodb://ccmongo:ccmongo@localhost:27017/collabclassroom?authSource=admin

# ── Redis (Local Docker → swap for Upstash URL in prod) ──
# Local:      redis://:ccredis@localhost:6379
# Production: rediss://default:TOKEN@HOST.upstash.io:6380
REDIS_URL=redis://:ccredis@localhost:6379

# ── AWS S3 ───────────────────────────────────────
# Set USE_S3=false to use the local filesystem stub during dev.
# Set USE_S3=true and fill in credentials for production.
USE_S3=false
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=collabclassroom-files

# ── CORS ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173
