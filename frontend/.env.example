# ─────────────────────────────────────────────────────────────────
#  Virtual Classroom — Frontend Environment (Vite)
#  Copy to .env and fill in values.
# ─────────────────────────────────────────────────────────────────

# Backend API URL (local dev: localhost, production: your deployed URL)
VITE_API_URL=http://localhost:8000

# WebSocket URL for Yjs collaboration
VITE_WS_URL=ws://localhost:8000

# Keycloak OIDC settings
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=virtual-classroom
VITE_KEYCLOAK_CLIENT_ID=virtual-classroom-frontend

# Frontend app URL (used for OIDC redirect_uri)
VITE_APP_URL=http://localhost:3000
