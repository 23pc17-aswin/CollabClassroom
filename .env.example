# ─────────────────────────────────────────────────────────────────
#  Virtual Classroom V2 — Root Environment Variables Example
#
#  Copy this file to .env and fill in real values.
#  Keys will be provided separately for production.
# ─────────────────────────────────────────────────────────────────

# ── Application ─────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────────
# Allowed frontend origin. In prod, replace with your deployed URL.
CORS_ORIGIN=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────────────
# Local Docker defaults shown. Replace with Neon URL for production.
POSTGRES_USER=vcadmin
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=virtualclassroom
# The full Prisma connection string (used inside the backend container)
DATABASE_URL=postgresql://vcadmin:your_postgres_password_here@localhost:5432/virtualclassroom

# ── MongoDB ──────────────────────────────────────────────────────
# Used for chat messages and study material metadata.
MONGO_USER=vcmongo
MONGO_PASSWORD=your_mongo_password_here
MONGO_DB=virtualclassroom
MONGO_URI=mongodb://vcmongo:your_mongo_password_here@localhost:27017/virtualclassroom?authSource=admin

# ── Redis ────────────────────────────────────────────────────────
# Socket.io Pub/Sub adapter + optional caching.
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6379

# ── Keycloak (Identity Provider) ─────────────────────────────────
# Admin credentials for the Keycloak admin console.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password_here
# Realm and client settings (created manually after first docker-compose up).
KEYCLOAK_REALM=virtual-classroom
KEYCLOAK_CLIENT_ID=virtual-classroom-backend
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret_here
# The public URL where Keycloak is reachable from browsers.
KEYCLOAK_URL=http://localhost:8080

# ── MinIO (S3-compatible File Storage) ───────────────────────────
MINIO_ROOT_USER=vcminio
MINIO_ROOT_PASSWORD=your_minio_password_here
# Internal endpoint used by the backend container (Docker service name).
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_NAME=virtualclassroom-files

# ── Admin Seed User (created by `npm run prisma:seed`) ───────────
SEED_ADMIN_EMAIL=admin@college.edu
SEED_ADMIN_NAME=Administrator
SEED_ADMIN_USERID=ADMIN001

# ── Vite Frontend Variables (prefix with VITE_) ──────────────────
# These are embedded at build time by Vite.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=virtual-classroom
VITE_KEYCLOAK_CLIENT_ID=virtual-classroom-frontend
# The public URL of your frontend app.
VITE_APP_URL=http://localhost:3000
